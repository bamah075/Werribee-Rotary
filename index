<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Werribee Rotary — Bulletin HTML Builder</title>
<style>
:root{--blue:#17458F;--blue-light:#E8EEF8;--blue-mid:#B5D4F4;--blue-dark:#0C447C;--gold:#F7A800;--gold-light:#FFFBF0;--gold-dark:#92400E;--ink:#1A1A2E;--muted:#6B7280;--pale:#F3F4F6;--surface:#F9FAFB;--border:#E5E7EB;--white:#ffffff;--radius:10px;--radius-sm:6px;font-family:'Segoe UI',system-ui,sans-serif;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:#ECEAE7;color:var(--ink);min-height:100vh;}
.app-header{background:var(--blue);padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;}
.app-logo{display:flex;align-items:center;gap:10px;}
.app-logo-badge{width:36px;height:36px;border-radius:50%;background:var(--gold);color:var(--blue);font-weight:900;font-size:.85rem;display:flex;align-items:center;justify-content:center;}
.app-logo-text strong{color:#fff;font-size:.95rem;display:block;}
.app-logo-text span{color:rgba(255,255,255,.55);font-size:.72rem;}
.app-tagline{color:rgba(255,255,255,.5);font-size:.72rem;text-transform:uppercase;letter-spacing:.1em;}
.app-body{display:grid;grid-template-columns:300px 1fr;min-height:calc(100vh - 58px);}
.sidebar{background:var(--white);border-right:1px solid var(--border);padding:1.25rem;display:flex;flex-direction:column;gap:6px;overflow-y:auto;}
.sidebar-label{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);padding:4px 0 8px;border-bottom:1px solid var(--border);margin-bottom:4px;}
.section-btn{display:flex;align-items:center;gap:10px;padding:9px 12px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--surface);cursor:pointer;text-align:left;transition:all .15s;width:100%;}
.section-btn:hover{background:var(--blue-light);border-color:#C5D5EF;}
.section-btn.active{background:var(--blue-light);border-color:var(--blue);border-left:3px solid var(--blue);}
.section-icon{width:28px;height:28px;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-size:.95rem;flex-shrink:0;}
.section-btn-info strong{display:block;font-size:.82rem;color:var(--ink);}
.section-btn-info span{font-size:.7rem;color:var(--muted);}
.editor-panel{display:flex;flex-direction:column;}
.editor-top{display:grid;grid-template-columns:1fr 1fr;flex:1;min-height:0;}
.form-area{padding:1.25rem;background:var(--white);border-right:1px solid var(--border);overflow-y:auto;max-height:calc(100vh - 260px);}
.form-area h2{font-size:.95rem;font-weight:700;color:var(--ink);margin-bottom:1rem;padding-bottom:10px;border-bottom:2px solid var(--gold);display:flex;align-items:center;gap:8px;}
.mode-tabs{display:flex;margin-bottom:1rem;border:1px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;}
.mode-tab{flex:1;padding:8px 12px;font-size:.8rem;font-weight:600;cursor:pointer;border:none;background:var(--surface);color:var(--muted);transition:all .15s;text-align:center;}
.mode-tab.active{background:var(--blue);color:#fff;}
.mode-tab:hover:not(.active){background:var(--blue-light);color:var(--blue-dark);}
.mode-panel{display:none;}
.mode-panel.active{display:block;}
.paste-hint{font-size:.72rem;color:var(--muted);margin-bottom:6px;line-height:1.6;background:var(--pale);padding:8px 10px;border-radius:var(--radius-sm);border-left:3px solid var(--gold);}
.paste-area{width:100%;min-height:180px;padding:10px 12px;border:1px solid var(--border);border-radius:var(--radius-sm);font-size:.84rem;font-family:'Courier New',monospace;color:var(--ink);resize:vertical;line-height:1.6;background:#FAFAFA;}
.paste-area:focus{outline:none;border-color:var(--blue);box-shadow:0 0 0 3px rgba(23,69,143,.08);}
.parse-btn{display:flex;align-items:center;gap:6px;background:var(--blue);color:#fff;border:none;border-radius:var(--radius-sm);padding:9px 16px;font-size:.82rem;font-weight:700;cursor:pointer;margin-top:8px;width:100%;justify-content:center;}
.parse-btn:hover{background:var(--blue-dark);}
.parse-result{margin-top:6px;font-size:.75rem;color:#059669;font-weight:600;padding:6px 10px;background:#ECFDF5;border-radius:var(--radius-sm);display:none;}
.field-group{margin-bottom:.9rem;}
.field-group label{display:block;font-size:.75rem;font-weight:600;color:var(--muted);margin-bottom:5px;text-transform:uppercase;letter-spacing:.06em;}
.field-group input,.field-group textarea,.field-group select{width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:var(--radius-sm);font-size:.86rem;color:var(--ink);font-family:inherit;background:var(--white);transition:border-color .15s;}
.field-group input:focus,.field-group textarea:focus,.field-group select:focus{outline:none;border-color:var(--blue);box-shadow:0 0 0 3px rgba(23,69,143,.08);}
.field-group textarea{resize:vertical;min-height:72px;line-height:1.5;}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.repeat-block{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;margin-bottom:8px;}
.repeat-block-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;}
.repeat-block-header strong{font-size:.78rem;color:var(--blue);}
.btn-remove{background:none;border:none;cursor:pointer;color:#EF4444;font-size:.75rem;font-weight:600;padding:2px 6px;border-radius:4px;}
.btn-remove:hover{background:#FEE2E2;}
.btn-add{display:flex;align-items:center;gap:6px;background:var(--blue-light);color:var(--blue-dark);border:1px dashed #C5D5EF;border-radius:var(--radius-sm);padding:8px 12px;font-size:.8rem;font-weight:600;cursor:pointer;width:100%;margin-top:4px;}
.btn-add:hover{background:#D0DEF5;}
.output-area{padding:1.25rem;background:#1E1E2E;overflow-y:auto;display:flex;flex-direction:column;}
.output-area h3{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:#7C85A2;margin-bottom:8px;}
.code-box{flex:1;background:#13131F;border-radius:var(--radius-sm);padding:14px;font-family:'Courier New',monospace;font-size:.76rem;color:#A8C7FA;line-height:1.65;white-space:pre-wrap;word-break:break-all;overflow-y:auto;min-height:200px;max-height:480px;border:1px solid #2D2D42;}
.copy-btn{margin-top:10px;background:var(--gold);color:var(--gold-dark);border:none;border-radius:var(--radius-sm);padding:10px 20px;font-size:.86rem;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:8px;transition:all .15s;}
.copy-btn:hover{background:#E09600;}
.copy-btn.copied{background:#059669;color:#fff;}
.preview-bar{border-top:1px solid var(--border);background:var(--white);padding:1rem 1.5rem;}
.preview-bar h3{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin-bottom:8px;}
.preview-frame{border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem;background:var(--white);max-width:620px;}
.welcome{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;text-align:center;padding:3rem;background:var(--white);}
.welcome-icon{width:64px;height:64px;border-radius:50%;background:var(--blue-light);color:var(--blue);font-size:1.75rem;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;}
.welcome h2{font-size:1.1rem;color:var(--ink);margin-bottom:.5rem;}
.welcome p{font-size:.86rem;color:var(--muted);max-width:300px;line-height:1.6;}
@media(max-width:900px){.app-body{grid-template-columns:1fr;}.editor-top{grid-template-columns:1fr;}}
</style>
</head>
<body>
<div class="app-header">
  <div class="app-logo">
    <div class="app-logo-badge">WR</div>
    <div class="app-logo-text"><strong>Rotary Bulletin Builder</strong><span>Werribee Rotary Club</span></div>
  </div>
  <div class="app-tagline">ClubRunner HTML Generator</div>
</div>
<div class="app-body">
  <div class="sidebar">
    <div class="sidebar-label">Choose a section to build</div>
    <button class="section-btn" onclick="showSection('events')" id="btn-events"><div class="section-icon" style="background:#E8EEF8;">📅</div><div class="section-btn-info"><strong>What's Coming Up</strong><span>Events table with dates</span></div></button>
    <button class="section-btn" onclick="showSection('president')" id="btn-president"><div class="section-icon" style="background:#FFFBF0;">✉️</div><div class="section-btn-info"><strong>President's Letter</strong><span>Weekly message</span></div></button>
    <button class="section-btn" onclick="showSection('impact')" id="btn-impact"><div class="section-icon" style="background:#ECFDF5;">📊</div><div class="section-btn-info"><strong>Impact Stats</strong><span>Funds raised, attendees</span></div></button>
    <button class="section-btn" onclick="showSection('roster')" id="btn-roster"><div class="section-icon" style="background:#FEF3C7;">🗓</div><div class="section-btn-info"><strong>Bingo / Roster</strong><span>Volunteer schedule</span></div></button>
    <button class="section-btn" onclick="showSection('breakfast')" id="btn-breakfast"><div class="section-icon" style="background:#FEF9C3;">☕</div><div class="section-btn-info"><strong>Breakfast Club</strong><span>Volunteer roster by day</span></div></button>
    <button class="section-btn" onclick="showSection('anniversaries')" id="btn-anniversaries"><div class="section-icon" style="background:#FBEAF0;">🎂</div><div class="section-btn-info"><strong>Anniversaries</strong><span>Birthdays &amp; milestones</span></div></button>
    <button class="section-btn" onclick="showSection('markers')" id="btn-markers"><div class="section-icon" style="background:#E8EEF8;">✅</div><div class="section-btn-info"><strong>Five Markers</strong><span>Belonging club card set</span></div></button>
    <button class="section-btn" onclick="showSection('story')" id="btn-story"><div class="section-icon" style="background:#F3F4F6;">📰</div><div class="section-btn-info"><strong>Community Story</strong><span>Feature article block</span></div></button>
    <button class="section-btn" onclick="showSection('speaker')" id="btn-speaker"><div class="section-icon" style="background:#EEEDFE;">🎤</div><div class="section-btn-info"><strong>Guest Speaker</strong><span>Speaker profile card</span></div></button>
    <button class="section-btn" onclick="showSection('footy')" id="btn-footy"><div class="section-icon" style="background:#ECFDF5;">🏉</div><div class="section-btn-info"><strong>AFL Tipping Comp</strong><span>Leaderboard & round results</span></div></button>
    <button class="section-btn" onclick="showSection('columns')" id="btn-columns"><div class="section-icon" style="background:#F3E8FF;">⬜</div><div class="section-btn-info"><strong>Column Layout</strong><span>1, 2 or 3 column blocks</span></div></button>
  </div>
  <div class="editor-panel">
    <div class="editor-top">
      <div class="form-area" id="form-area">
        <div class="welcome">
          <div class="welcome-icon">🏗️</div>
          <h2>Pick a section to start</h2>
          <p>Choose any section from the left. Fill in the fields <strong>or switch to Paste Text</strong> to paste raw content — HTML generates instantly.</p>
        </div>
      </div>
      <div class="output-area">
        <h3>Generated HTML — copy &amp; paste into ClubRunner</h3>
        <div class="code-box" id="code-output"><!-- HTML appears here --></div>
        <button class="copy-btn" id="copy-btn" onclick="copyCode()">📋 Copy HTML to clipboard</button>
      </div>
    </div>
    <div class="preview-bar">
      <h3>Live preview</h3>
      <div class="preview-frame" id="preview-frame"><p style="color:#9CA3AF;font-size:.85rem;text-align:center;padding:1rem 0;">Preview appears here as you type</p></div>
    </div>
  </div>
</div>

<script>
let currentSection=null;
const BLUE='#17458F',GOLD='#F7A800',BLUE_LIGHT='#E8EEF8',BLUE_MID='#B5D4F4',BORDER='#E5E7EB',MUTED='#6B7280',INK='#1A1A2E',SURFACE='#F9FAFB';

function modeTabs(key,hint){
  return `<div class="mode-tabs">
    <button class="mode-tab active" onclick="switchMode('${key}','form',this)">✏️ Fill in fields</button>
    <button class="mode-tab" onclick="switchMode('${key}','paste',this)">📋 Paste text</button>
  </div>
  <div class="mode-panel active" id="${key}-form-panel"></div>
  <div class="mode-panel" id="${key}-paste-panel">
    <p class="paste-hint">${hint}</p>
    <textarea class="paste-area" id="${key}-paste-raw" rows="10" placeholder="Paste your raw text here..."></textarea>
    <button class="parse-btn" onclick="parseSection('${key}')">⚡ Parse &amp; Generate HTML</button>
    <div class="parse-result" id="${key}-parse-result">✅ Parsed! Switch to fields to review or edit.</div>
  </div>`;
}

function switchMode(key,mode,btn){
  document.querySelectorAll(`#${key}-form-panel,#${key}-paste-panel`).forEach(p=>p.classList.remove('active'));
  document.getElementById(`${key}-${mode}-panel`).classList.add('active');
  btn.closest('.mode-tabs').querySelectorAll('.mode-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

function showResult(key){
  const el=document.getElementById(`${key}-parse-result`);
  if(!el)return;
  el.style.display='block';
  setTimeout(()=>{el.style.display='none';},3000);
}

function showSection(name){
  currentSection=name;
  document.querySelectorAll('.section-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('btn-'+name).classList.add('active');
  const fa=document.getElementById('form-area');
  ({events,president,impact,roster,breakfast,anniversaries,markers,story,speaker,footy,columns})[name]?.(fa);
}

function update(){
  const gens={events:genEvents,president:genPresident,impact:genImpact,roster:genRoster,breakfast:genBreakfast,anniversaries:genAnniversaries,markers:genMarkers,story:genStory,speaker:genSpeaker,footy:genFooty,columns:genColumns};
  if(currentSection&&gens[currentSection]){
    const html=gens[currentSection]();
    document.getElementById('code-output').textContent=html;
    document.getElementById('preview-frame').innerHTML=html;
  }
}

function parseSection(key){
  const raw=document.getElementById(`${key}-paste-raw`)?.value||'';
  ({events:parseEvents,president:parsePresident,impact:parseImpact,roster:parseRoster,breakfast:parseBreakfast,anniversaries:parseAnniversaries,markers:parseMarkers,story:parseStory,speaker:parseSpeaker,footy:parseFooty})[key]?.(raw);
  showResult(key);
  // Switch back to form tab
  const tabs=document.getElementById(`${key}-form-panel`)?.previousElementSibling;
  if(tabs){const ft=tabs.querySelector('.mode-tab');if(ft)switchMode(key,'form',ft);}
  update();
}

function copyCode(){
  const code=document.getElementById('code-output').textContent;
  navigator.clipboard.writeText(code).then(()=>{
    const btn=document.getElementById('copy-btn');
    btn.textContent='✅ Copied!';btn.classList.add('copied');
    setTimeout(()=>{btn.innerHTML='📋 Copy HTML to clipboard';btn.classList.remove('copied');},2000);
  });
}

/* ── EVENTS ── */
let eventRows=[
  {day:'Tuesday',date:'12 May 2026',event:'Club Meeting',topic:'',venue:'The Bridge Hotel',type:'meeting'},
  {day:'Thursday',date:'21 May 2026',event:'Bunnings BBQ',topic:'Bunnings BBQ',venue:'Bunnings Hoppers Crossing',type:'bbq'},
];
function events(fa){
  fa.innerHTML=`<h2><span>📅</span> What's Coming Up</h2>${modeTabs('events','One row per line: Day, Date, Event, Topic, Venue — separated by commas.\nExample:\nTuesday, 12 May 2026, Club Meeting, Guest Speaker, Bridge Hotel\nThursday, 21 May 2026, Bunnings BBQ, Bunnings BBQ, Hoppers Crossing')}`;
  document.getElementById('events-form-panel').innerHTML=`<div class="field-group"><label>Subtitle</label><input id="ev-sub" value="Next week — dates subject to change" oninput="update()"></div><div id="ev-rows"></div><button class="btn-add" onclick="addEventRow()">+ Add row</button>`;
  renderEventRows();update();
}
function renderEventRows(){
  const c=document.getElementById('ev-rows');if(!c)return;
  c.innerHTML=eventRows.map((r,i)=>`<div class="repeat-block"><div class="repeat-block-header"><strong>Row ${i+1}</strong><button class="btn-remove" onclick="removeEventRow(${i})">✕</button></div>
    <div class="field-row"><div class="field-group"><label>Day</label><input value="${r.day}" oninput="eventRows[${i}].day=this.value;update()"></div><div class="field-group"><label>Date</label><input value="${r.date}" oninput="eventRows[${i}].date=this.value;update()"></div></div>
    <div class="field-row"><div class="field-group"><label>Event</label><input value="${r.event}" oninput="eventRows[${i}].event=this.value;update()"></div><div class="field-group"><label>Type</label><select onchange="eventRows[${i}].type=this.value;update()"><option value="meeting" ${r.type==='meeting'?'selected':''}>Meeting (blue)</option><option value="bbq" ${r.type==='bbq'?'selected':''}>Bunnings BBQ (amber)</option><option value="special" ${r.type==='special'?'selected':''}>Special (gold)</option><option value="social" ${r.type==='social'?'selected':''}>Social (teal)</option></select></div></div>
    <div class="field-row"><div class="field-group"><label>Topic</label><input value="${r.topic}" placeholder="TBA" oninput="eventRows[${i}].topic=this.value;update()"></div><div class="field-group"><label>Venue</label><input value="${r.venue}" oninput="eventRows[${i}].venue=this.value;update()"></div></div>
  </div>`).join('');
}
function addEventRow(){eventRows.push({day:'Tuesday',date:'',event:'Club Meeting',topic:'',venue:'The Bridge Hotel',type:'meeting'});renderEventRows();update();}
function removeEventRow(i){eventRows.splice(i,1);renderEventRows();update();}
function parseEvents(raw){
  const lines=raw.trim().split('\n').filter(l=>l.trim());
  eventRows=lines.map(l=>{const p=l.split(/[,\t]/).map(s=>s.trim());const e=p[2]||'Club Meeting';const t=/bbq/i.test(e)?'bbq':/christmas|special/i.test(e)?'special':/social/i.test(e)?'social':'meeting';return{day:p[0]||'',date:p[1]||'',event:e,topic:p[3]||'',venue:p[4]||'',type:t};});
  renderEventRows();
}
function bStyle(t){if(t==='bbq')return'background:#FEF3C7;color:#92400E';if(t==='special')return'background:#FFFBF0;color:#B87D00';if(t==='social')return'background:#E1F5EE;color:#085041';return`background:${BLUE_LIGHT};color:#0C447C`;}
function genEvents(){
  const sub=document.getElementById('ev-sub')?.value||'Next week — dates subject to change';
  const rows=eventRows.map((r,i)=>{const bg=i%2===0?'#fff':SURFACE;const tc=r.topic?`<td style="padding:10px 12px;border-bottom:1px solid ${BORDER};background:${bg};color:#374151;font-size:13px;">${r.topic}</td>`:`<td style="padding:10px 12px;border-bottom:1px solid ${BORDER};background:${bg};color:#9CA3AF;font-style:italic;font-size:13px;">TBA</td>`;return`  <tr><td style="padding:10px 12px;border-bottom:1px solid ${BORDER};border-left:4px solid ${GOLD};background:${bg};"><div style="font-weight:700;color:${INK};font-size:14px;font-family:Arial,sans-serif;">${r.day}</div><div style="color:${MUTED};font-size:12px;margin-top:1px;font-family:Arial,sans-serif;">${r.date}</div></td><td style="padding:10px 12px;border-bottom:1px solid ${BORDER};background:${bg};"><span style="display:inline-block;${bStyle(r.type)};font-size:12px;font-weight:700;padding:3px 9px;border-radius:4px;font-family:Arial,sans-serif;">${r.event}</span></td>${tc}<td style="padding:10px 12px;border-bottom:1px solid ${BORDER};background:${bg};color:#374151;font-size:13px;font-family:Arial,sans-serif;">${r.venue}</td></tr>`;}).join('\n');
  return `<p style="font-family:Arial,sans-serif;font-size:20px;font-weight:700;color:${INK};margin:0 0 6px 0;">What's Coming Up</p>\n<div style="height:3px;background:${GOLD};margin:0 0 6px 0;"></div>\n<p style="font-family:Arial,sans-serif;font-size:13px;color:${MUTED};margin:0 0 14px 0;">${sub}</p>\n<table style="width:100%;border-collapse:collapse;font-family:Arial,sans-serif;font-size:14px;">\n  <thead><tr><th style="background:${BLUE};color:${BLUE_MID};padding:10px 12px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;width:26%;">Date</th><th style="background:${BLUE};color:${BLUE_MID};padding:10px 12px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;width:20%;">Event</th><th style="background:${BLUE};color:${BLUE_MID};padding:10px 12px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;width:27%;">Topic</th><th style="background:${BLUE};color:${BLUE_MID};padding:10px 12px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;width:27%;">Venue</th></tr></thead>\n  <tbody>\n${rows}\n  </tbody>\n</table>`;
}

/* ── PRESIDENT ── */
function president(fa){
  fa.innerHTML=`<h2><span>✉️</span> President's Letter</h2>${modeTabs('president',"Paste Lyn's full letter as plain text.\nFirst paragraph = the opening quote shown in italics.\nAll other paragraphs = body text.")}`;
  document.getElementById('president-form-panel').innerHTML=`
    <div class="field-group"><label>President Name</label><input id="pr-name" value="Lyn Fava" oninput="update()"></div>
    <div class="field-group"><label>Title / Role</label><input id="pr-role" value="Club President 2025–26" oninput="update()"></div>
    <div class="field-group"><label>Opening quote / key message</label><textarea id="pr-quote" rows="3" oninput="update()">"What an extraordinary week for our club. Seeing 1,500 people come together reminded me why we do what we do."</textarea></div>
    <div class="field-group"><label>Body paragraph (optional)</label><textarea id="pr-body" rows="4" oninput="update()">The community's response was humbling — and it's all down to you and your dedication to service above self.</textarea></div>
    <div class="field-group"><label>Initials (for avatar)</label><input id="pr-initials" value="LF" maxlength="3" oninput="update()"></div>`;
  update();
}
function parsePresident(raw){
  const p=raw.trim().split(/\n+/).filter(l=>l.trim());
  const q=document.getElementById('pr-quote');if(q)q.value=p[0]||'';
  const b=document.getElementById('pr-body');if(b)b.value=p.slice(1).join(' ');
}
function genPresident(){
  const name=document.getElementById('pr-name')?.value||'';const role=document.getElementById('pr-role')?.value||'';const quote=document.getElementById('pr-quote')?.value||'';const body=document.getElementById('pr-body')?.value||'';const ini=document.getElementById('pr-initials')?.value||'LF';
