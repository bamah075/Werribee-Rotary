let footyMeta={roundLabel:'Round 6, 7 & 8 — Results',weeklyPrize:'Rd6 Robyn / Rd7 Bradd / Rd8 Robyn',bonusTip:'Rd7 Mary & Rd8 Ann',leader:'MezBeth (Mary)',leaderScore:'58',weeklyAmount:'$20'};

function footy(fa){
