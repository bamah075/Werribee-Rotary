}
function addFootyRow(){ footyRows.push({rank:String(footyRows.length+1),name:'',r7:'',r8:'',score:'',margin:'',highlight:''}); renderFootyRows(); update(); }
function removeFootyRow(i){ footyRows.splice(i,1); renderFootyRows(); update(); }

function parseFooty(raw){
  const lines=raw.trim().split('\n').filter(l=>l.trim());
  // Detect meta lines (no numbers at start)
  const dataLines=[];
  lines.forEach(line=>{
    const clean=line.trim();
    // Check if line starts with a number — it's a data row
    if(/^\d+/.test(clean)){
      // Split by tabs first, then commas, then 2+ spaces
      let parts=clean.split('\t').map(s=>s.trim());
      if(parts.length<4) parts=clean.split(',').map(s=>s.trim());
      if(parts.length<4) parts=clean.split(/\s{2,}/).map(s=>s.trim());
      const rankStr=parts[0]||'';
      const rank=rankStr.replace(/\D/g,'');
      const name=parts[1]||'';
      const r7=parts[2]||'';
      const r8=parts[3]||'';
      const score=parts[4]||'';
      const margin=parts[5]||'';
      // Auto-detect highlight: prize keywords in name
      let highlight='';
      if(/\$20|\$\d+|prize/i.test(name)&&!/x\s*\$|2\s*x/i.test(name)) highlight='prize';
      if(/2\s*x|double/i.test(name)) highlight='prize';
      // Check for asterisk markers
      if(clean.endsWith('**')) highlight='bonus';
      else if(clean.endsWith('*')) highlight='winner';
      // Mark perfect round (score==10 or r7==10 or r8==10)
      if(r7==='10'||r8==='10') highlight=highlight||'winner';
      dataLines.push({rank,name:name.replace(/\*+$/,'').trim(),r7,r8,score,margin,highlight});
    }
  });
  if(dataLines.length>0) footyRows=dataLines;
  renderFootyRows();
}

function footyRowStyle(h){
  if(h==='winner') return 'background:#FEF9C3;';
  if(h==='prize')  return 'background:#DCFCE7;';
  if(h==='bonus')  return 'background:#FEE2E2;';
  if(h==='leader') return 'background:#DBEAFE;';
  return '';
}
function footyCellStyle(h,base){
  const bg=footyRowStyle(h);
  return bg?`padding:7px 10px;border-bottom:1px solid ${BORDER};${bg}font-family:Arial,sans-serif;font-size:13px;`:
            `padding:7px 10px;border-bottom:1px solid ${BORDER};background:${base};font-family:Arial,sans-serif;font-size:13px;`;
}

