function speaker(fa){
  fa.innerHTML=`<h2><span>🎤</span> Guest Speaker</h2>${modeTabs('speaker','Paste speaker details as plain text.\nLine 1: Full name\nLine 2: Title / Organisation\nLine 3: Topic (or prefix with "Topic:")\nRemaining lines: Bio\nAny line starting with http: presentation link')}`;
  document.getElementById('speaker-form-panel').innerHTML=`
    <div class="field-group"><label>Speaker Name</label><input id="sp-name" value="Joe Smith" oninput="update()"></div>
    <div class="field-group"><label>Title / Organisation</label><input id="sp-role" value="CEO, Community Foundation" oninput="update()"></div>
    <div class="field-group"><label>Topic</label><input id="sp-topic" value="Building Stronger Communities" oninput="update()"></div>
    <div class="field-group"><label>Short bio</label><textarea id="sp-bio" rows="3" oninput="update()">Joe has spent 20 years working across community organisations in the Wyndham region, leading projects that have supported thousands of families.</textarea></div>
    <div class="field-group"><label>Initials (for avatar)</label><input id="sp-initials" value="JS" maxlength="3" oninput="update()"></div>
    <div class="field-group"><label>Presentation link URL (optional)</label><input id="sp-link" placeholder="https://..." oninput="update()"></div>`;
  update();
}
function parseSpeaker(raw){
  const lines=raw.trim().split('\n').filter(l=>l.trim());
  const n=document.getElementById('sp-name');if(n)n.value=lines[0]||'';
  const r=document.getElementById('sp-role');if(r)r.value=lines[1]||'';
  const tl=lines.find(l=>/^topic[:\s]/i.test(l));
  const t=document.getElementById('sp-topic');if(t)t.value=tl?tl.replace(/^topic[:\s]*/i,'').trim():lines[2]||'';
  const link=lines.find(l=>l.startsWith('http'));
  const sl=document.getElementById('sp-link');if(sl&&link)sl.value=link;
  const bio=lines.slice(3).filter(l=>!l.startsWith('http')&&!/^topic/i.test(l)).join(' ');
  const sb=document.getElementById('sp-bio');if(sb)sb.value=bio;
  const ini=(lines[0]||'').split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
  const si=document.getElementById('sp-initials');if(si)si.value=ini;
}
function genSpeaker(){
  const name=document.getElementById('sp-name')?.value||'';const role=document.getElementById('sp-role')?.value||'';const topic=document.getElementById('sp-topic')?.value||'';const bio=document.getElementById('sp-bio')?.value||'';const ini=document.getElementById('sp-initials')?.value||'JS';const link=document.getElementById('sp-link')?.value||'';
  return `<p style="font-family:Arial,sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:#B87D00;margin:0 0 6px 0;">Tonight's Guest Speaker</p>\n<p style="font-family:Arial,sans-serif;font-size:20px;font-weight:700;color:${INK};margin:0 0 16px 0;border-bottom:2px solid ${GOLD};padding-bottom:8px;">${name}</p>\n<table style="border-collapse:collapse;width:100%;margin-bottom:14px;"><tr><td style="width:60px;vertical-align:top;padding-right:16px;"><div style="width:52px;height:52px;border-radius:50%;background:${BLUE};color:${BLUE_MID};font-family:Arial,sans-serif;font-size:1rem;font-weight:700;text-align:center;line-height:52px;">${ini}</div></td><td style="vertical-align:top;"><p style="font-family:Arial,sans-serif;font-size:14px;font-weight:700;color:${BLUE};margin:0 0 2px 0;">${role}</p><p style="font-family:Arial,sans-serif;font-size:13px;color:${MUTED};margin:0 0 10px 0;">Topic: <strong style="color:${INK};">${topic}</strong></p><p style="font-family:Arial,sans-serif;font-size:13px;color:#374151;line-height:1.7;margin:0;">${bio}</p></td></tr></table>\n${link?`<a href="${link}" style="display:inline-block;background:${BLUE};color:#fff;font-family:Arial,sans-serif;font-size:13px;font-weight:700;padding:8px 18px;border-radius:5px;text-decoration:none;">View Presentation →</a>`:''}`;
