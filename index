function parseStory(raw){
  const p=raw.trim().split(/\n+/).filter(l=>l.trim());
  const h=document.getElementById('st-headline');if(h)h.value=p[0]||'';
  const body=p.slice(1).filter(x=>!x.startsWith('http')&&!/^[""]/.test(x));
