function addBreakfastRow(){breakfastRows.push({day:'Tuesday',date:'',volunteers:''});renderBreakfastRows();update();}
function removeBreakfastRow(i){breakfastRows.splice(i,1);renderBreakfastRows();update();}
function parseBreakfast(raw){
  const lines=raw.trim().split('\n').filter(l=>l.trim());
  breakfastRows=lines.map(line=>{
    const clean=line.replace(/\s+/g,' ').trim();
    const dm=clean.match(/^(MONDAY|TUESDAY|WEDNESDAY|THURSDAY|FRIDAY|SATURDAY|SUNDAY)/i);
    const day=dm?dm[1].charAt(0).toUpperCase()+dm[1].slice(1).toLowerCase():'Tuesday';
    const rest=clean.replace(/^(MONDAY|TUESDAY|WEDNESDAY|THURSDAY|FRIDAY|SATURDAY|SUNDAY)\s*/i,'');
    const dateM=rest.match(/^([A-Za-z]+\.?\s+\d+)\s+(.*)/);
    if(dateM)return{day,date:dateM[1].trim(),volunteers:dateM[2].trim()};
    const parts=rest.split(/\s{2,}/);
    return{day,date:parts[0]||'',volunteers:parts.slice(1).join(' ').trim()};
  });
  renderBreakfastRows();
}
function dayBadge(d){if(d==='Wednesday')return'background:#FEF3C7;color:#92400E';if(d==='Thursday')return'background:#ECFDF5;color:#065041';if(d==='Friday')return'background:#F3E8FF;color:#5B21B6';return`background:${BLUE_LIGHT};color:#0C447C`;}
