        <p style="font-family:Arial,sans-serif;font-size:13px;color:#374151;margin:0;">${prize}</p>
        ${bonus?`<p style="font-family:Arial,sans-serif;font-size:13px;color:#374151;margin:4px 0 0 0;"><strong>Good Tipping — 9/9 + Bonus:</strong> ${bonus}</p>`:''}
      </td>
