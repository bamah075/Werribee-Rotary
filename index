  const quote=p.find(x=>/^[""]/.test(x));
  const p2=document.getElementById('st-p2');if(p2)p2.value=quote||'';
  const link=p.find(x=>x.startsWith('http'));
  const lu=document.getElementById('st-link-url');if(lu&&link)lu.value=link;
}
