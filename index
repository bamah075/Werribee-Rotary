/* ── COLUMN LAYOUT ── */
let colCount = 2;
let colData = [
  { title: '', content: '', bg: 'white', border: true },
  { title: '', content: '', bg: 'white', border: true },
];
const COL_BG = { white: '#ffffff', blue: '#E8EEF8', gold: '#FFFBF0', grey: '#F9FAFB', dark: '#17458F' };
const COL_TITLE_CLR = { white: '#1A1A2E', blue: '#0C447C', gold: '#92400E', grey: '#1A1A2E', dark: '#ffffff' };
const COL_TEXT_CLR  = { white: '#374151', blue: '#1A1A2E', gold: '#374151', grey: '#374151', dark: '#B5D4F4' };

function columns(fa) {
  fa.innerHTML = `<h2><span>⬜</span> Column Layout</h2>`;

  // Column count picker — visual tiles
  fa.innerHTML += `
  <div class="field-group">
    <label>Number of Columns</label>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-top:4px;" id="col-picker">
      ${[1,2,3].map(n=>`
        <button onclick="setColCount(${n})" id="col-pick-${n}"
          style="padding:14px 8px;border-radius:8px;border:2px solid ${n===colCount?'var(--blue)':'var(--border)'};
          background:${n===colCount?'var(--blue-light)':'var(--surface)'};cursor:pointer;font-family:inherit;">
          <div style="font-size:1.2rem;margin-bottom:4px;">${'▮'.repeat(n)}</div>
          <div style="font-size:.78rem;font-weight:700;color:${n===colCount?'var(--blue)':'var(--muted)'};">${n} Column${n>1?'s':''}</div>
        </button>`).join('')}
    </div>
  </div>
  <div class="field-group">
    <label>Gap between columns</label>
    <select id="col-gap" onchange="update()">
      <option value="0">None</option>
      <option value="8" selected>Small (8px)</option>
      <option value="16">Medium (16px)</option>
      <option value="24">Large (24px)</option>
    </select>
  </div>
  <div id="col-panels"></div>`;

  renderColPanels();
  update();
}

function setColCount(n) {
  colCount = n;
  // Grow or shrink colData to match
  while (colData.length < n) colData.push({ title:'', content:'', bg:'white', border:true });
  colData = colData.slice(0, n);
  // Re-render picker highlights
  [1,2,3].forEach(i => {
    const btn = document.getElementById(`col-pick-${i}`);
    if (!btn) return;
    btn.style.borderColor = i===n ? 'var(--blue)' : 'var(--border)';
    btn.style.background  = i===n ? 'var(--blue-light)' : 'var(--surface)';
    btn.querySelector('div:last-child').style.color = i===n ? 'var(--blue)' : 'var(--muted)';
  });
  renderColPanels();
  update();
}

function renderColPanels() {
  const c = document.getElementById('col-panels'); if (!c) return;
  const labels = colCount===1 ? ['Column'] : colCount===2 ? ['Left column','Right column'] : ['Left column','Centre column','Right column'];
  c.innerHTML = colData.map((col, i) => `
    <div style="border:1px solid var(--border);border-radius:8px;padding:12px;margin-bottom:10px;background:var(--surface);">
      <div style="font-size:.78rem;font-weight:700;color:var(--blue);margin-bottom:10px;text-transform:uppercase;letter-spacing:.06em;">
        ${labels[i]}
      </div>
      <div class="field-group">
        <label>Heading (optional)</label>
        <input value="${col.title.replace(/"/g,'&quot;')}" oninput="colData[${i}].title=this.value;update()">
      </div>
      <div class="field-group">
        <label>Content — paste your HTML or plain text</label>
        <textarea rows="5" style="font-size:.8rem;" oninput="colData[${i}].content=this.value;update()">${col.content.replace(/</g,'&lt;')}</textarea>
      </div>
      <div class="field-row">
        <div class="field-group">
          <label>Background</label>
          <select onchange="colData[${i}].bg=this.value;update()">
            <option value="white"  ${col.bg==='white' ?'selected':''}>White</option>
            <option value="blue"   ${col.bg==='blue'  ?'selected':''}>Light Blue</option>
            <option value="gold"   ${col.bg==='gold'  ?'selected':''}>Light Gold</option>
            <option value="grey"   ${col.bg==='grey'  ?'selected':''}>Light Grey</option>
            <option value="dark"   ${col.bg==='dark'  ?'selected':''}>Navy Blue</option>
          </select>
        </div>
        <div class="field-group">
          <label>Border</label>
          <select onchange="colData[${i}].border=(this.value==='true');update()">
            <option value="true"  ${col.border ?'selected':''}>Show border</option>
            <option value="false" ${!col.border?'selected':''}>No border</option>
          </select>
        </div>
      </div>
    </div>`).join('');
}

function genColumns() {
  const gap = document.getElementById('col-gap')?.value || '8';
  const pct = colCount===1?'100%':colCount===2?'50%':'33.33%';

  const cells = colData.map(col => {
    const bg     = COL_BG[col.bg]      || '#ffffff';
    const titleC = COL_TITLE_CLR[col.bg] || INK;
    const textC  = COL_TEXT_CLR[col.bg]  || '#374151';
    const border = col.border ? `border:1px solid ${BORDER};` : '';
    const goldBar = col.bg==='dark'
      ? `<div style="height:3px;background:${GOLD};margin-bottom:10px;border-radius:2px;"></div>`
      : (col.title ? `<div style="height:2px;background:${GOLD};margin-bottom:10px;border-radius:2px;"></div>` : '');

    // Convert plain text to paragraphs if no HTML tags detected
    let body = col.content;
    if (body && !/<[a-z]/i.test(body)) {
      body = body.trim().split(/\n+/).map(p =>
        `<p style="font-family:Arial,sans-serif;font-size:14px;color:${textC};line-height:1.7;margin:0 0 8px 0;">${p}</p>`
      ).join('\n');
    }

    return `<td style="width:${pct};vertical-align:top;padding:${gap}px;">
  <div style="background:${bg};${border}border-radius:8px;padding:16px;height:100%;">
    ${col.title ? `<p style="font-family:Arial,sans-serif;font-size:15px;font-weight:700;color:${titleC};margin:0 0 6px 0;">${col.title}</p>${goldBar}` : ''}
    ${body}
  </div>
</td>`;
  }).join('\n');

  return `<table style="width:100%;border-collapse:collapse;table-layout:fixed;">
  <tr>
${cells}
  </tr>
</table>`;
}
</script>
