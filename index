  {rank:'4',name:'philsbombers',r7:'8',r8:'8',score:'53',margin:'204',highlight:''},
  {rank:'5',name:'tiger1949',r7:'8',r8:'7',score:'53',margin:'208',highlight:''},
  {rank:'6',name:'Robyn Ballan - 2x $20',r7:'8',r8:'8',score:'53',margin:'222',highlight:'prize'},
  {rank:'7',name:'SmithRossA',r7:'8',r8:'8',score:'53',margin:'245',highlight:''},
