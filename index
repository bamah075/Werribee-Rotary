  return `<p style="font-family:Arial,sans-serif;font-size:20px;font-weight:700;color:${INK};margin:0 0 4px 0;">🏉 Werribee Rotary AFL Tipping Comp</p>
<div style="height:3px;background:${GOLD};margin:0 0 14px 0;"></div>
